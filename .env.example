# ─────────────────────────────────────────────────────────────────
#  FsocietyPK – Frontend Environment Variables
#  Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────────────────────────

# API origin (required)
VITE_API_URL=http://16.171.55.64:5000

# Optional API path prefix.
# Keep empty if backend routes are mounted at root (e.g. /health, /auth/login).
# Set to /api/v1 if backend uses /api/v1/* routes.
VITE_API_PREFIX=/api/v1

# Cookie-based auth toggle for cross-origin requests.
# Keep true if backend uses HTTP-only auth cookies and CORS allows credentials.
VITE_API_WITH_CREDENTIALS=true

# App metadata
VITE_APP_NAME=FsocietyPK
VITE_APP_DESCRIPTION=Pakistan's Premier CTF Platform

# Feature flags
VITE_ENABLE_REGISTRATION=true
VITE_MAINTENANCE_MODE=false
